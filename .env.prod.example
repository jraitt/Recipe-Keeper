# Production Environment Variables for Recipe Keeper

# Database Configuration
POSTGRES_DB=recipes
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-secure-production-password
DATABASE_URL=postgresql://postgres:your-secure-production-password@db:5432/recipes

# Google Gemini API
GEMINI_API_KEY=your-production-gemini-api-key

# Application Settings
NODE_ENV=production
JWT_SECRET=your-super-secure-jwt-secret-key-for-production
JWT_EXPIRES_IN=7d
PORT=3021

# Port Configuration
FRONTEND_PORT=3020
BACKEND_PORT=3021
DB_PORT=5432

# File Upload Configuration
MAX_FILE_SIZE=20971520
UPLOAD_PATH=./uploads

# Rate Limiting (Production - More restrictive)
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX_REQUESTS=30

# Production Security Settings
CORS_ORIGIN=https://your-domain.com
FORCE_HTTPS=true
LOG_LEVEL=info

# Security Headers
HELMET_ENABLED=true
TRUST_PROXY=true

# Optional: SSL Configuration
SSL_CERT_PATH=/etc/ssl/certs/your-cert.pem
SSL_KEY_PATH=/etc/ssl/private/your-key.pem

# Optional: External Services
REDIS_URL=redis://redis:6379
SENTRY_DSN=your-sentry-dsn-for-error-tracking