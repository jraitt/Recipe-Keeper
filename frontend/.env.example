# Frontend Environment Variables

# API Configuration
VITE_API_URL=http://localhost:3021/api
VITE_API_TIMEOUT=30000

# Authentication
VITE_JWT_SECRET=your-jwt-secret-here
VITE_JWT_EXPIRES_IN=7d

# Application Settings
VITE_APP_NAME=Recipe Keeper
VITE_APP_VERSION=1.0.0
VITE_APP_DESCRIPTION=AI-powered recipe storage and management

# Development Settings
VITE_NODE_ENV=development
VITE_DEBUG=true
VITE_LOG_LEVEL=debug

# Feature Flags
VITE_ENABLE_AI_FEATURES=true
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_PWA=true

# External Services
VITE_ANALYTICS_ID=your-analytics-id
VITE_SENTRY_DSN=your-sentry-dsn

# UI Configuration
VITE_DEFAULT_THEME=light
VITE_ENABLE_DARK_MODE=true
VITE_ITEMS_PER_PAGE=20

# File Upload
VITE_MAX_FILE_SIZE=5242880
VITE_ACCEPTED_IMAGE_TYPES=image/jpeg,image/png,image/webp